{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{test_*.py,__pycache__/**,wardrobe/photos/**,wardrobe/shopping_cache.json}"
    }
  }
}
